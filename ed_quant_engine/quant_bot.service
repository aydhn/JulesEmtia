[Unit]
Description=ED Capital Quant Engine Daemon
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/ed_quant_engine
ExecStart=/usr/local/bin/docker-compose -f /opt/ed_quant_engine/docker-compose.yml up
ExecStop=/usr/local/bin/docker-compose -f /opt/ed_quant_engine/docker-compose.yml stop
Restart=always
RestartSec=10
Environment="TZ=Europe/Istanbul"

[Install]
WantedBy=multi-user.target
